<!DOCTYPE html>
<html>
  <head>
    <title>Travel Journal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body>
      
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="navbar-brand ms-3">Travel Journal</div>
  <div class="ms-auto me-3">
    <% if current_user %>
      <span class="text-white me-3">Welcome, <%= current_user["username"] %>!</span>
      <form action="/sessions/1" method="post" style="display:inline">
        <input type="hidden" name="_method" value="delete">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <button type="submit" class="btn btn-outline-light">Logout</button>
      </form>
    <% else %>
      <a href="/sessions/new" class="btn btn-outline-light me-2">Login</a>
      <a href="/users/new" class="btn btn-light">Signup</a>
    <% end %>
  </div>
</nav>
    <div class="container mt-4">
  <%= flash["notice"] %>
  <%= yield %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
